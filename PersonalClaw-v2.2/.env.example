# ========================================
# PersonalClaw v2.2 - Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# ========================================
# LLM PROVIDERS
# ========================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini (Google)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Ollama (Local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Default LLM Provider (anthropic, openai, gemini, or ollama)
LLM_PROVIDER=anthropic

# ========================================
# TELEGRAM BOT
# ========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ========================================
# VOICE INTERFACE
# ========================================
# Speech-to-Text (Deepgram or OpenAI Whisper)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Text-to-Speech (ElevenLabs or OpenAI TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ========================================
# EMAIL INTEGRATION
# ========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password_here
EMAIL_FROM=your_email@gmail.com

# ========================================
# SECURITY
# ========================================
# Emergency unlock code for Guardian Agent
EMERGENCY_UNLOCK_CODE=your_secure_unlock_code_here

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=18789
HOST=127.0.0.1
NODE_ENV=development

# ========================================
# OPTIONAL FEATURES
# ========================================
# Screen watching
SCREEN_WATCH_ENABLED=false
SCREEN_WATCH_INTERVAL=30000

# Browser automation
BROWSER_HEADLESS=true
