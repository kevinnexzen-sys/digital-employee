{
  "name": "personalclaw",
  "version": "2.2.0",
  "description": "PersonalClaw - AI Digital Employee Assistant",
  "main": "desktop/main.js",
  "type": "module",
  "scripts": {
    "start": "electron desktop/main.js",
    "desktop": "electron desktop/main.js",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "guardian": "node guardian-agent.js",
    "test": "node final-system-test.js"
  },
  "keywords": [
    "ai",
    "assistant",
    "automation",
    "digital-employee"
  ],
  "author": "KevinNexzen",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.28.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0",
    "fs-extra": "^11.2.0",
    "nodemailer": "^6.9.9",
    "node-telegram-bot-api": "^0.64.0",
    "axios": "^1.6.7",
    "node-screenshots": "^0.2.8",
    "tesseract.js": "^5.0.4",
    "playwright": "^1.41.2",
    "better-sqlite3": "^9.4.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "build": {
    "appId": "com.personalclaw.app",
    "productName": "PersonalClaw",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "package.json",
      ".env.example"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "desktop/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
